# =========================================
# Webapp Builder - Environment Variables
# Copy this file to .env.local and fill values
# =========================================

# ---------- App ----------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_ROOT_DOMAIN="example.com"          # 例: yourservice.com
NEXT_PUBLIC_APP_SUBDOMAIN="app"                # 管理画面用サブドメイン想定

# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Prisma(PostgreSQL) 接続文字列（Supabase DB URL）
DATABASE_URL="postgresql://postgres:password@localhost:5432/webapp?schema=public"

# ---------- Google OAuth (Supabase Auth用) ----------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------- Stripe (TEST MODE) ----------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# ベースプラン / トッピング price_id（Stripeダッシュボードで発行）
STRIPE_BASE_PRICE_ID="price_base_1480"
STRIPE_TOPPING_EXTRA_PAGES_PRICE_ID="price_topping_extra_pages"
STRIPE_TOPPING_CONTACT_FORM_PRICE_ID="price_topping_contact_form"
STRIPE_TOPPING_BLOG_PRICE_ID="price_topping_blog"
STRIPE_TOPPING_SNS_PRICE_ID="price_topping_sns"
STRIPE_TOPPING_MAP_PRICE_ID="price_topping_map"
STRIPE_TOPPING_CUSTOM_DOMAIN_PRICE_ID="price_topping_custom_domain"
STRIPE_TOPPING_SEO_PRICE_ID="price_topping_seo"
STRIPE_TOPPING_GA_PRICE_ID="price_topping_ga"
STRIPE_TOPPING_BOOKING_PRICE_ID="price_topping_booking"
STRIPE_TOPPING_HIBERNATION_PRICE_ID="price_topping_hibernation"

# ---------- Email / Media ----------
RESEND_API_KEY="re_xxx"
UNSPLASH_ACCESS_KEY="YOUR_UNSPLASH_ACCESS_KEY"

# ---------- Optional: Cloudflare for SaaS ----------
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ZONE_ID=""

# ---------- Optional: Vercel ----------
VERCEL_PROJECT_ID=""
VERCEL_ORG_ID=""
