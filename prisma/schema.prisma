generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @db.Uuid
  email         String
  planStatus    String?        @map("plan_status")
  createdAt     DateTime       @default(now()) @map("created_at")
  sites         Site[]
  subscriptions Subscription[]

  @@map("Users")
}

model Site {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  subdomain       String        @unique
  customDomain    String?       @map("custom_domain")
  templateId      String?       @map("template_id") @db.Uuid
  colorTheme      String?       @map("color_theme")
  customColors    Json?         @map("custom_colors")
  font            String?
  content         Json?
  sectionsOrder   Json?         @map("sections_order")
  sectionsVisible Json?         @map("sections_visible")
  isPublished     Boolean       @default(false) @map("is_published")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  user            User          @relation(fields: [userId], references: [id])
  template        Template?     @relation(fields: [templateId], references: [id])
  siteToppings    SiteTopping[]
  subscriptions   Subscription[]
  pages           Page[]
  blogPosts       BlogPost[]
  formFields      FormField[]
  contactMessages ContactMessage[]

  @@map("Sites")
}

model Template {
  id              String   @id @default(uuid()) @db.Uuid
  businessType    String   @map("business_type")
  style           String
  name            String
  thumbnailUrl    String?  @map("thumbnail_url")
  defaultSections Json?    @map("default_sections")
  createdAt       DateTime @default(now()) @map("created_at")
  sites           Site[]

  @@map("Templates")
}

model Topping {
  id            String        @id @default(uuid()) @db.Uuid
  name          String
  description   String
  price         Int
  stripePriceId String?       @map("stripe_price_id")
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")
  siteToppings  SiteTopping[]

  @@map("Toppings")
}

model SiteTopping {
  id           String   @id @default(uuid()) @db.Uuid
  siteId       String   @map("site_id") @db.Uuid
  toppingId    String   @map("topping_id") @db.Uuid
  isEnabled    Boolean  @default(false) @map("is_enabled")
  stripeItemId String?  @map("stripe_item_id")
  enabledAt    DateTime? @map("enabled_at")
  createdAt    DateTime @default(now()) @map("created_at")
  site         Site     @relation(fields: [siteId], references: [id])
  topping      Topping  @relation(fields: [toppingId], references: [id])

  @@map("SiteToppings")
}

model Subscription {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  siteId           String   @map("site_id") @db.Uuid
  stripeSubId      String?  @map("stripe_sub_id")
  stripeCusId      String?  @map("stripe_cus_id")
  status           String?
  currentPeriodEnd DateTime? @map("current_period_end")
  createdAt        DateTime @default(now()) @map("created_at")
  user             User     @relation(fields: [userId], references: [id])
  site             Site     @relation(fields: [siteId], references: [id])

  @@map("Subscriptions")
}

model Page {
  id          String   @id @default(uuid()) @db.Uuid
  siteId      String   @map("site_id") @db.Uuid
  title       String
  slug        String
  content     Json?
  isPublished Boolean  @default(false) @map("is_published")
  order       Int?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  site        Site     @relation(fields: [siteId], references: [id])

  @@map("Pages")
}

model BlogPost {
  id           String   @id @default(uuid()) @db.Uuid
  siteId        String   @map("site_id") @db.Uuid
  title         String
  body          Json?
  thumbnailUrl  String?  @map("thumbnail_url")
  isPublished   Boolean  @default(false) @map("is_published")
  publishedAt   DateTime? @map("published_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  site          Site     @relation(fields: [siteId], references: [id])

  @@map("BlogPosts")
}

model FormField {
  id         String   @id @default(uuid()) @db.Uuid
  siteId     String   @map("site_id") @db.Uuid
  label      String
  fieldType  String   @map("field_type")
  isRequired Boolean  @default(false) @map("is_required")
  order      Int?
  createdAt  DateTime @default(now()) @map("created_at")
  site       Site     @relation(fields: [siteId], references: [id])

  @@map("FormFields")
}

model ContactMessage {
  id        String   @id @default(uuid()) @db.Uuid
  siteId    String   @map("site_id") @db.Uuid
  answers   Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  site      Site     @relation(fields: [siteId], references: [id])

  @@map("ContactMessages")
}
